---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FullBleedImage from "../../components/FullBleedImage.astro";
import FullBleedPlaceholder from "../../components/FullBleedPlaceholder.astro";
import CaseImage from "../../components/CaseImage.astro";
import ArrowLink from "../../components/ui/ArrowLink.astro";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const all = (await getCollection("projects")).sort(
    // Same ordering as index.astro — tie-break on id so prev/next matches
    // the homepage card order even when publishDates collide.
    (a, b) =>
      b.data.publishDate.valueOf() - a.data.publishDate.valueOf() ||
      a.id.localeCompare(b.id),
  );

  return all.map((entry, i) => ({
    params: { id: entry.data.slug },
    props: {
      entry,
      // Wrap-around: "Next project →" is NEWER (lower index, wraps to oldest).
      // "← Previous project" is OLDER (higher index, wraps to newest).
      nextEntry: all[(i - 1 + all.length) % all.length],
      prevEntry: all[(i + 1) % all.length],
    },
  }));
}

type Props = {
  entry: CollectionEntry<"projects">;
  nextEntry: CollectionEntry<"projects">;
  prevEntry: CollectionEntry<"projects">;
};

const { entry, nextEntry, prevEntry } = Astro.props as Props;
const { Content } = await render(entry);

const timeline = entry.data.publishDate.toLocaleDateString("en-US", {
  month: "long",
  year: "numeric",
});

// Header metadata grid — items without a value are skipped, so placeholder
// projects (no company/team yet) never render an empty label.
const metadata = [
  { label: "Role", value: entry.data.role },
  { label: "Team", value: entry.data.team },
  { label: "Timeline", value: entry.data.timelineRange ?? timeline },
  { label: "Tools", value: entry.data.tools },
].filter((item) => item.value);

// Hero srcset widths: normal display needs ~1152px, but click-to-zoom sets
// sizes="100vw" and can render near the full viewport, so emit high-res
// candidates too. Cap at the source width (filter out anything larger) to
// avoid upscaling and Astro's "width exceeds original" warning.
const heroWidths = [
  ...[400, 800, 1200, 1800, 2400].filter((w) => w < entry.data.thumbnail.width),
  entry.data.thumbnail.width,
];
---

<BaseLayout
  title={`${entry.data.title} — Tanya Zakus, Design Engineer`}
  description={entry.data.summary}
  ogImage="/og-image.png"
  ogType="article"
>
  {/* Back link */}
  <div
    class="container pt-[var(--spacing-lg)] animate-page-entry"
    style="--entry-index: 0"
  >
    <ArrowLink href="/#projects" direction="left">Back to work</ArrowLink>
  </div>

  {/* Header — title, summary, metadata */}
  <header
    class="container pt-[var(--spacing-xl)] pb-10 animate-page-entry"
    style="--entry-index: 1"
  >
    <h1
      class="text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] mb-[var(--spacing-lg)] max-w-[20ch] text-[var(--color-text-primary)]"
    >
      {entry.data.title}
    </h1>

    <p
      class="text-xl md:text-2xl text-[var(--color-text-secondary)] max-w-[55ch] leading-relaxed mb-[var(--spacing-lg)]"
    >
      {entry.data.summary}
    </p>

    {
      /* Metadata — 4-column grid (Company / Role / Team / Timeline), 2×2 on mobile */
    }
    <dl
      class="mt-[var(--spacing-xl)] grid grid-cols-2 md:grid-cols-4 gap-[var(--spacing-lg)]"
    >
      {
        metadata.map(({ label, value }) => (
          <div>
            <dt class="text-xs tracking-widest uppercase text-[var(--color-text-secondary)] mb-[var(--spacing-sm)]">
              {label}
            </dt>
            <dd class="m-0 text-sm text-[var(--color-text-secondary)]">
              {value}
            </dd>
          </div>
        ))
      }
    </dl>
  </header>

  {/* Hero image */}
  <div
    class="container mb-[3.5rem] md:mb-[var(--spacing-3xl)] animate-page-entry"
    style="--entry-index: 2"
  >
    <div class="rounded-2xl overflow-hidden bg-[var(--color-secondary)]">
      <Image
        src={entry.data.thumbnail}
        alt={`Cover image for ${entry.data.title}`}
        format="webp"
        widths={heroWidths}
        sizes="(min-width: 1200px) 1152px, calc(100vw - 3rem)"
        class="w-full aspect-[16/9] object-cover rounded-2xl"
        data-zoomable
      />
    </div>
  </div>

  {/* Body article — MDX prose + prev/next */}
  <article
    class="container pb-[var(--spacing-2xl)] md:pb-[var(--spacing-4xl)] animate-page-entry"
    style="--entry-index: 3"
  >
    <div class="case-prose">
      <Content components={{ FullBleedImage, FullBleedPlaceholder, CaseImage }} />
    </div>

    <nav
      class="mt-[var(--spacing-2xl)] md:mt-[var(--spacing-3xl)] pt-[var(--spacing-lg)] md:pt-[var(--spacing-xl)] border-t border-[var(--color-border)] flex justify-between gap-[var(--spacing-md)]"
      aria-label="Case study navigation"
    >
      <a
        href={`/projects/${prevEntry.data.slug}`}
        class="group flex-1 flex flex-col min-h-[44px] py-[var(--spacing-sm)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
      >
        <ArrowLink decorative direction="left">Previous project</ArrowLink>
        <span
          class="mt-[var(--spacing-xs)] text-base text-[var(--color-text-primary)]"
          >{prevEntry.data.title}</span
        >
      </a>
      <a
        href={`/projects/${nextEntry.data.slug}`}
        class="group flex-1 flex flex-col items-end min-h-[44px] py-[var(--spacing-sm)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
      >
        <ArrowLink decorative direction="right">Next project</ArrowLink>
        <span
          class="mt-[var(--spacing-xs)] text-base text-right text-[var(--color-text-primary)]"
          >{nextEntry.data.title}</span
        >
      </a>
    </nav>
  </article>
</BaseLayout>

<script>
  // Click-to-zoom for the hero cover image (img[data-zoomable]). Loaded here so
  // it works on every case study, not only ones whose MDX includes a CaseImage
  // (which imports the same module). Astro dedupes the shared import.
  import "../../scripts/image-zoom.ts";
</script>

<style is:global>
  /* MDX prose — reuses the About-page section layout: full-width divider,
     display-serif heading in a 1fr left rail, body copy in the remaining 3fr.
     MDX output is flat (h2/p/figure siblings), so grid auto-placement does
     the sectioning: h2 → column 1, everything else → column 2. */
  .case-prose {
    display: grid;
    grid-template-columns: 1fr;
    row-gap: var(--spacing-md);
  }
  .case-prose > h2 {
    position: relative;
    font-size: var(--text-display);
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-text-primary);
    /* 32px margin + the grid's 16px row-gap = 48px above the divider;
       48px padding below it — matches the About-page mobile dividers. */
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-2xl);
  }
  /* Section divider above each h2 — full row width on mobile, widened to
     span both grid columns on desktop. None above the first section. */
  .case-prose > h2::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--color-border);
  }
  /* First section (mobile): keeps its divider; the hero image's bottom
     margin (56px — +8px optical, hard image edge above) supplies the gap
     above the line, so no margin of its own. */
  .case-prose > h2:first-child {
    margin-top: 0;
  }
  .case-prose h3 {
    font-family: var(--font-serif);
    font-size: 1.5rem; /* 24px — reference text-2xl */
    line-height: 1.3;
    color: var(--color-text-primary);
    margin-top: var(--spacing-md);
  }
  /* Inline subheader within a subsection — mirrors the CaseCard title
     (serif via the global h1–h4 rule, 20px, medium, primary). The negative
     bottom margin nets the 16px row-gap down to a 12px title→body gap.
     Direct-child only: CaseCard renders its own (nested) h4 title. */
  .case-prose > h4 {
    font-size: 1.25rem; /* 20px — reference text-xl */
    font-weight: 500;
    line-height: 1.375;
    color: var(--color-text-primary);
    margin-top: var(--spacing-sm);
    margin-bottom: calc(-1 * var(--spacing-xs));
  }
  .case-prose p {
    font-size: 1.125rem; /* 18px — site-wide body standard */
    line-height: 1.625;
    color: var(--color-text-secondary);
    margin: 0;
  }
  /* Emphasis in body copy is color-only: primary against the secondary
     body text, at body weight — browser-default 700 bold reads too heavy. */
  .case-prose strong {
    font-weight: 400;
    color: var(--color-text-primary);
  }
  /* List body copy — same voice as p, with a round dot marker hung in
     the gutter. Scoped to lists authored in MDX — direct children of the
     prose, or slotted into a CaseAccordion (> details) — so embedded
     components' own lists stay untouched. */
  .case-prose > ul,
  .case-prose > details ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    row-gap: var(--spacing-lg);
  }
  /* Inside accordions, items space like body paragraphs (16px prose rhythm). */
  .case-prose > details ul {
    row-gap: var(--spacing-md);
  }
  .case-prose > ul li,
  .case-prose > details ul li {
    position: relative;
    /* 24px indent − 8px dot = 16px gap between marker and text */
    padding-left: var(--spacing-lg);
    font-size: 1.125rem; /* 18px — matches .case-prose p */
    line-height: 1.625;
    color: var(--color-text-secondary);
  }
  .case-prose > ul li::before,
  .case-prose > details ul li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em; /* optically centers on the first text line */
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-text-secondary);
  }
  /* Consecutive accordion rows sit flush (divider to divider) — the
     negative margin cancels the prose grid's 16px row-gap. */
  .case-prose > details + details {
    margin-top: calc(-1 * var(--spacing-md));
  }
  /* Full-bleed image ending the prose: give it the same vertical rhythm as a
     section divider so whitespace above and below matches the rest of the page.
     Drop its bottom margin and let the nav own the gap below. Mobile divider
     rhythm is 3rem/3rem (h2 margin-top xl + row-gap md above; padding-top 2xl
     below), so: gap above = row-gap md + margin-top xl = 3rem; gap below =
     nav margin-top 2xl = 3rem. Desktop bumps both a step (see media query). */
  .case-prose > .full-bleed:last-child {
    margin-top: var(--spacing-xl);
    margin-bottom: 0;
  }
  .case-prose:has(> .full-bleed:last-child) + nav {
    margin-top: var(--spacing-2xl);
  }
  @media (min-width: 64rem) {
    .case-prose {
      grid-template-columns: 1fr 3fr;
      column-gap: var(--spacing-2xl);
    }
    .case-prose > h2 {
      grid-column: 1;
      margin-top: var(--spacing-2xl);
      padding-top: var(--spacing-3xl);
    }
    .case-prose > :not(h2) {
      grid-column: 2;
    }
    /* Full-bleed figures must span the whole grid, not the 3fr content
       column — their 100vw break-out (margin-left: calc(-50vw + 50%)) is
       computed against the containing block, so an off-centre column lands
       the image shifted right. Spanning 1/-1 restores a centred container. */
    .case-prose > .full-bleed {
      grid-column: 1 / -1;
    }
    /* Desktop divider rhythm is a step larger (h2 margin-top 2xl + padding-top
       3xl), so bump the image gap to match: gap above = row-gap md + margin-top
       2xl = 4rem; gap below = nav margin-top 3xl = 4rem. */
    .case-prose > .full-bleed:last-child {
      margin-top: var(--spacing-2xl);
    }
    .case-prose:has(> .full-bleed:last-child) + nav {
      margin-top: var(--spacing-3xl);
    }
    /* Desktop divider spans both grid columns (rail is 1fr of a 1fr+3fr
       grid: full row width = 4×rail + gap). */
    .case-prose > h2::before {
      width: calc(400% + var(--spacing-2xl));
    }
    /* Desktop keeps the first section divider-free — the hero image alone
       separates it from the page header. */
    .case-prose > h2:first-child {
      margin-top: 0;
      padding-top: 0;
    }
    .case-prose > h2:first-child::before {
      display: none;
    }
    /* First block of a section shares the h2's row — match its top offsets
       so heading and copy stay top-aligned below the divider. */
    .case-prose > h2 + * {
      margin-top: var(--spacing-2xl);
      padding-top: var(--spacing-3xl);
    }
    /* ...except the first section's block: no divider above it, so no
       offsets to mirror. Desktop-scoped — on mobile the block must keep
       its own margin (e.g. an h3's margin-top). */
    .case-prose > h2:first-child + * {
      margin-top: 0;
      padding-top: 0;
    }
  }
</style>
