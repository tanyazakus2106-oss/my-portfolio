---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FullBleedImage from '../../components/FullBleedImage.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const all = (await getCollection('projects'))
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

  return all.map((entry, i) => ({
    params: { id: entry.id },
    props: {
      entry,
      // Wrap-around: "Next project →" is NEWER (lower index, wraps to oldest).
      // "← Previous project" is OLDER (higher index, wraps to newest).
      nextEntry: all[(i - 1 + all.length) % all.length],
      prevEntry: all[(i + 1) % all.length],
    },
  }));
}

type Props = {
  entry: CollectionEntry<'projects'>;
  nextEntry: CollectionEntry<'projects'>;
  prevEntry: CollectionEntry<'projects'>;
};

const { entry, nextEntry, prevEntry } = Astro.props as Props;
const { Content } = await render(entry);

// Timeline formatting — placeholder MDX has only publishDate, so we render the month+year
// as a single-point timeline. Real case studies can override by adding explicit timeline
// text in MDX body if needed.
const timeline = entry.data.publishDate.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={`${entry.data.title} — Tanya Zakus`}>
  <div class="max-w-[1200px] mx-auto px-[var(--spacing-lg)] md:px-[var(--spacing-2xl)] lg:px-[var(--spacing-3xl)] pt-[var(--spacing-3xl)] pb-[var(--spacing-3xl)]">
    {/* Centered column — per D-12 */}
    <article class="max-w-[760px] mx-auto">

      {/* 1. Back link (D-11, CONTEXT Specifics) */}
      <a
        href="/work"
        class="inline-block text-[13px] uppercase tracking-[0.08em] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
      >
        ← Back to work
      </a>

      {/* 2. Category labels — role + skills (D-11, D-14) */}
      <p class="mt-[var(--spacing-2xl)] text-[13px] uppercase tracking-[0.08em] text-[var(--color-text-secondary)]">
        {[entry.data.role, ...entry.data.skills].join(' · ')}
      </p>

      {/* 3. H1 title (Heading role per UI-SPEC) */}
      <h1 class="mt-[var(--spacing-md)] text-2xl font-semibold leading-[1.25] text-[var(--color-text-primary)]">
        {entry.data.title}
      </h1>

      {/* 4. Summary tagline (Body role) */}
      <p class="mt-[var(--spacing-md)] text-base leading-[1.6] text-[var(--color-text-secondary)]">
        {entry.data.summary}
      </p>

      {/* 5. Metadata block (D-11) */}
      <dl class="mt-[var(--spacing-xl)] grid grid-cols-1 md:grid-cols-3 gap-[var(--spacing-md)] p-[var(--spacing-lg)] rounded-lg bg-[var(--color-secondary)]">
        <div>
          <dt class="text-[13px] uppercase tracking-[0.08em] text-[var(--color-text-secondary)]">Timeline</dt>
          <dd class="mt-[var(--spacing-xs)] text-base text-[var(--color-text-primary)]">{timeline}</dd>
        </div>
        <div>
          <dt class="text-[13px] uppercase tracking-[0.08em] text-[var(--color-text-secondary)]">Team</dt>
          <dd class="mt-[var(--spacing-xs)] text-base text-[var(--color-text-primary)]">Placeholder — update in MDX</dd>
        </div>
        <div>
          <dt class="text-[13px] uppercase tracking-[0.08em] text-[var(--color-text-secondary)]">My Role</dt>
          <dd class="mt-[var(--spacing-xs)] text-base text-[var(--color-text-primary)]">{entry.data.role}</dd>
        </div>
      </dl>

      {/* Divider — D-11 + UI-SPEC */}
      <hr class="mt-[var(--spacing-xl)] border-t border-[var(--color-border)]" />

      {/* 6. First project image — constrained to column, WebP via Astro <Image> (D-13, CASE-05) */}
      <div class="mt-[var(--spacing-xl)] overflow-hidden rounded-lg">
        <Image
          src={entry.data.thumbnail}
          alt={`Cover image for ${entry.data.title}`}
          format="webp"
          widths={[600, 1200]}
          sizes="(min-width: 768px) 760px, 100vw"
          class="w-full h-auto"
        />
      </div>

      {/* 7. MDX body — Problem / My Role / Process / Outcome. FullBleedImage injected. */}
      {/* The case-prose wrapper gives consistent typography to the MDX body markdown. */}
      <div class="mt-[var(--spacing-2xl)] case-prose">
        <Content components={{ FullBleedImage }} />
      </div>

      {/* 8. Next/prev navigation — D-16, wrap-around */}
      <nav
        class="mt-[var(--spacing-4xl)] pt-[var(--spacing-xl)] border-t border-[var(--color-border)] flex justify-between gap-[var(--spacing-md)]"
        aria-label="Case study navigation"
      >
        <a
          href={`/projects/${prevEntry.id}`}
          class="group flex flex-col min-h-[44px] py-[var(--spacing-sm)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
        >
          <span class="text-[13px] uppercase tracking-[0.08em]">← <span class="group-hover:underline underline-offset-4">Previous project</span></span>
          <span class="mt-[var(--spacing-xs)] text-base text-[var(--color-text-primary)]">{prevEntry.data.title}</span>
        </a>
        <a
          href={`/projects/${nextEntry.id}`}
          class="group flex flex-col items-end min-h-[44px] py-[var(--spacing-sm)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
        >
          <span class="text-[13px] uppercase tracking-[0.08em]"><span class="group-hover:underline underline-offset-4">Next project</span> →</span>
          <span class="mt-[var(--spacing-xs)] text-base text-[var(--color-text-primary)]">{nextEntry.data.title}</span>
        </a>
      </nav>
    </article>
  </div>

  <script>
    // Observe MDX section headings on case study pages — extends the shared
    // scroll-animation behavior. D-20, POL-01.
    import '../../scripts/scroll-animation.ts';

    const h2s = document.querySelectorAll<HTMLElement>('.case-prose h2');
    if (h2s.length > 0) {
      const prefersReducedMotion =
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) {
        h2s.forEach((el) => el.classList.add('is-visible'));
      } else {
        h2s.forEach((el, i) => {
          el.style.setProperty('--stagger-index', String(i));
        });
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        h2s.forEach((el) => observer.observe(el));
      }
    }
  </script>
</BaseLayout>

<style is:global>
  /* Typography + animate-on-scroll hooks for MDX-rendered section headings.
     MDX h2 elements (## Problem, ## My Role, etc.) land here. Apply muted uppercase
     Label style per D-14 + UI-SPEC §Case Study Page. D-15 override — NO accent color.
     We scope via .case-prose so global h2 usage (e.g. work.astro) is unaffected. */
  .case-prose h2 {
    font-size: 13px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-md);
    /* Animate-on-scroll participation — D-20. */
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 500ms ease-out,
      transform 500ms ease-out;
    transition-delay: calc(var(--stagger-index, 0) * 60ms);
  }
  .case-prose h2.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .case-prose h2 {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
  .case-prose p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-primary);
    margin-top: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }
</style>
