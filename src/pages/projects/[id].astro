---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FullBleedImage from '../../components/FullBleedImage.astro';
import ArrowLink from '../../components/ui/ArrowLink.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const all = (await getCollection('projects'))
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

  return all.map((entry, i) => ({
    params: { id: entry.id },
    props: {
      entry,
      // Wrap-around: "Next project →" is NEWER (lower index, wraps to oldest).
      // "← Previous project" is OLDER (higher index, wraps to newest).
      nextEntry: all[(i - 1 + all.length) % all.length],
      prevEntry: all[(i + 1) % all.length],
    },
  }));
}

type Props = {
  entry: CollectionEntry<'projects'>;
  nextEntry: CollectionEntry<'projects'>;
  prevEntry: CollectionEntry<'projects'>;
};

const { entry, nextEntry, prevEntry } = Astro.props as Props;
const { Content } = await render(entry);

const timeline = entry.data.publishDate.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title={`${entry.data.title} — Tanya Zakus, UX/UI Designer`}
  description={entry.data.summary}
  ogImage="/og-image.png"
  ogType="article"
>

  {/* Back link */}
  <div class="max-w-[1200px] mx-auto px-[var(--spacing-lg)] pt-[var(--spacing-lg)] animate-page-entry" style="--entry-index: 0">
    <ArrowLink href="/#projects" direction="left">Back to work</ArrowLink>
  </div>

  {/* Header — eyebrow, title, summary, metadata */}
  <header class="max-w-[1200px] mx-auto px-[var(--spacing-lg)] pt-[var(--spacing-xl)] pb-[var(--spacing-xl)] animate-page-entry" style="--entry-index: 1">
    <p class="text-xs tracking-widest uppercase text-[var(--color-text-secondary)] mb-[var(--spacing-md)]">
      {[entry.data.role, ...entry.data.skills].join(', ')}
    </p>

    <h1 class="text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] mb-[var(--spacing-lg)] max-w-[20ch] text-[var(--color-text-primary)]">
      {entry.data.title}
    </h1>

    <p class="text-xl md:text-2xl text-[var(--color-text-secondary)] max-w-[55ch] leading-relaxed mb-[var(--spacing-lg)]">
      {entry.data.summary}
    </p>

    {/* Timeline + team — single block, two stacked rows, no card */}
    <dl class="mt-[var(--spacing-lg)]">
      <dt class="text-xs tracking-widest uppercase text-[var(--color-text-secondary)] mb-[var(--spacing-sm)]">Timeline</dt>
      <dd class="m-0 text-sm text-[var(--color-text-secondary)]">{entry.data.timelineRange ?? timeline}</dd>
      <dd class="m-0 mt-[var(--spacing-xs)] text-sm text-[var(--color-text-secondary)]">{entry.data.team ?? 'Placeholder team — update in MDX'}</dd>
    </dl>
  </header>

  {/* Hero image */}
  <div class="max-w-[1200px] mx-auto px-[var(--spacing-lg)] mb-[var(--spacing-2xl)] animate-page-entry" style="--entry-index: 2">
    <div class="rounded-2xl overflow-hidden bg-[var(--color-secondary)]">
      <Image
        src={entry.data.thumbnail}
        alt={`Cover image for ${entry.data.title}`}
        format="webp"
        widths={[900, 1800]}
        sizes="(min-width: 1200px) 1152px, calc(100vw - 3rem)"
        class="w-full h-auto"
      />
    </div>
  </div>

  {/* Body article — MDX prose + prev/next */}
  <article class="max-w-[720px] mx-auto px-[var(--spacing-lg)] pb-[var(--spacing-4xl)] case-prose animate-page-entry" style="--entry-index: 3">

    <Content components={{ FullBleedImage }} />

    <nav
      class="mt-[var(--spacing-3xl)] pt-[var(--spacing-xl)] border-t border-[var(--color-border)] flex justify-between gap-[var(--spacing-md)]"
      aria-label="Case study navigation"
    >
      <a
        href={`/projects/${prevEntry.id}`}
        class="group flex flex-col min-h-[44px] py-[var(--spacing-sm)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
      >
        <ArrowLink decorative direction="left">Previous project</ArrowLink>
        <span class="mt-[var(--spacing-xs)] text-base text-[var(--color-text-primary)]">{prevEntry.data.title}</span>
      </a>
      <a
        href={`/projects/${nextEntry.id}`}
        class="group flex flex-col items-end min-h-[44px] py-[var(--spacing-sm)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
      >
        <ArrowLink decorative direction="right">Next project</ArrowLink>
        <span class="mt-[var(--spacing-xs)] text-base text-[var(--color-text-primary)]">{nextEntry.data.title}</span>
      </a>
    </nav>
  </article>

</BaseLayout>

<style is:global>
  /* MDX prose styling — adapted to reference layout (tushar.work).
     Body H2/H3 are serif at larger sizes (replacing the prior small-uppercase
     label style). Animate-on-scroll behavior preserved. */
  .case-prose h2 {
    font-family: var(--font-serif);
    font-size: 1.875rem; /* 30px */
    line-height: 1.2;
    color: var(--color-text-primary);
    margin-top: var(--spacing-3xl); /* 64px */
    margin-bottom: var(--spacing-lg); /* 24px */
  }
  .case-prose h3 {
    font-family: var(--font-serif);
    font-size: 1.5rem; /* 24px */
    line-height: 1.3;
    color: var(--color-text-primary);
    margin-top: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }
  .case-prose p {
    font-size: 1.125rem;
    line-height: 1.625;
    color: var(--color-text-secondary);
    margin-top: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }
</style>
