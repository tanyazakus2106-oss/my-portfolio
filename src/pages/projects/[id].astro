---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FullBleedImage from '../../components/FullBleedImage.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const all = (await getCollection('projects'))
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

  return all.map((entry, i) => ({
    params: { id: entry.id },
    props: {
      entry,
      // Wrap-around: "Next project →" is NEWER (lower index, wraps to oldest).
      // "← Previous project" is OLDER (higher index, wraps to newest).
      nextEntry: all[(i - 1 + all.length) % all.length],
      prevEntry: all[(i + 1) % all.length],
    },
  }));
}

type Props = {
  entry: CollectionEntry<'projects'>;
  nextEntry: CollectionEntry<'projects'>;
  prevEntry: CollectionEntry<'projects'>;
};

const { entry, nextEntry, prevEntry } = Astro.props as Props;
const { Content } = await render(entry);

const timeline = entry.data.publishDate.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={`${entry.data.title} — Tanya Zakus`}>

  {/* Back link */}
  <div class="max-w-[1200px] mx-auto px-[var(--spacing-lg)] pt-[var(--spacing-lg)]">
    <a
      href="/work"
      class="group inline-flex items-center gap-[var(--spacing-sm)] text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
    >
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
      </svg>
      Back to work
    </a>
  </div>

  {/* Header — eyebrow, title, summary, metadata */}
  <header class="max-w-[1200px] mx-auto px-[var(--spacing-lg)] pt-[var(--spacing-xl)] pb-[var(--spacing-xl)]">
    <p class="text-xs tracking-widest uppercase text-[var(--color-text-secondary)] mb-[var(--spacing-md)]">
      {[entry.data.role, ...entry.data.skills].join(', ')}
    </p>

    <h1 class="text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] mb-[var(--spacing-lg)] max-w-[20ch] text-[var(--color-text-primary)]">
      {entry.data.title}
    </h1>

    <p class="text-xl md:text-2xl text-[var(--color-text-secondary)] max-w-[55ch] leading-relaxed mb-[var(--spacing-lg)]">
      {entry.data.summary}
    </p>

    {/* Timeline / Team / My Role — 3-col grid on desktop, stacked on mobile, no card */}
    <dl class="mt-[var(--spacing-lg)] grid grid-cols-1 md:grid-cols-3 gap-[var(--spacing-lg)] max-w-[55ch]">
      <div>
        <dt class="text-xs tracking-widest uppercase text-[var(--color-text-secondary)] mb-[var(--spacing-sm)]">Timeline</dt>
        <dd class="text-sm text-[var(--color-text-secondary)]">{timeline}</dd>
      </div>
      <div>
        <dt class="text-xs tracking-widest uppercase text-[var(--color-text-secondary)] mb-[var(--spacing-sm)]">Team</dt>
        <dd class="text-sm text-[var(--color-text-secondary)]">Placeholder — update in MDX</dd>
      </div>
      <div>
        <dt class="text-xs tracking-widest uppercase text-[var(--color-text-secondary)] mb-[var(--spacing-sm)]">My Role</dt>
        <dd class="text-sm text-[var(--color-text-secondary)]">{entry.data.role}</dd>
      </div>
    </dl>
  </header>

  {/* Hero image */}
  <div class="max-w-[1200px] mx-auto px-[var(--spacing-lg)] mb-[var(--spacing-2xl)]">
    <div class="rounded-2xl overflow-hidden bg-[var(--color-secondary)]">
      <Image
        src={entry.data.thumbnail}
        alt={`Cover image for ${entry.data.title}`}
        format="webp"
        widths={[900, 1800]}
        sizes="(min-width: 1200px) 1152px, calc(100vw - 3rem)"
        class="w-full h-auto"
      />
    </div>
  </div>

  {/* Body article — MDX prose + prev/next */}
  <article class="max-w-[720px] mx-auto px-[var(--spacing-lg)] pb-[var(--spacing-4xl)] case-prose">

    <Content components={{ FullBleedImage }} />

    <nav
      class="mt-[var(--spacing-3xl)] pt-[var(--spacing-xl)] border-t border-[var(--color-border)] flex justify-between gap-[var(--spacing-md)]"
      aria-label="Case study navigation"
    >
      <a
        href={`/projects/${prevEntry.id}`}
        class="group flex flex-col min-h-[44px] py-[var(--spacing-sm)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
      >
        <span class="text-xs tracking-widest uppercase">← Previous project</span>
        <span class="mt-[var(--spacing-xs)] text-sm text-[var(--color-text-primary)]">{prevEntry.data.title}</span>
      </a>
      <a
        href={`/projects/${nextEntry.id}`}
        class="group flex flex-col items-end min-h-[44px] py-[var(--spacing-sm)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
      >
        <span class="text-xs tracking-widest uppercase">Next project →</span>
        <span class="mt-[var(--spacing-xs)] text-sm text-[var(--color-text-primary)]">{nextEntry.data.title}</span>
      </a>
    </nav>
  </article>

  <script>
    import '../../scripts/scroll-animation.ts';

    const h2s = document.querySelectorAll<HTMLElement>('.case-prose h2');
    if (h2s.length > 0) {
      const prefersReducedMotion =
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) {
        h2s.forEach((el) => el.classList.add('is-visible'));
      } else {
        h2s.forEach((el, i) => {
          el.style.setProperty('--stagger-index', String(i));
        });
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        h2s.forEach((el) => observer.observe(el));
      }
    }
  </script>
</BaseLayout>

<style is:global>
  /* MDX prose styling — adapted to reference layout (tushar.work).
     Body H2/H3 are serif at larger sizes (replacing the prior small-uppercase
     label style). Animate-on-scroll behavior preserved. */
  .case-prose h2 {
    font-family: var(--font-serif);
    font-size: 1.875rem; /* 30px */
    line-height: 1.2;
    color: var(--color-text-primary);
    margin-top: var(--spacing-3xl); /* 64px */
    margin-bottom: var(--spacing-lg); /* 24px */
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 500ms ease-out,
      transform 500ms ease-out;
    transition-delay: calc(var(--stagger-index, 0) * 60ms);
  }
  .case-prose h2.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .case-prose h3 {
    font-family: var(--font-serif);
    font-size: 1.5rem; /* 24px */
    line-height: 1.3;
    color: var(--color-text-primary);
    margin-top: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }
  .case-prose p {
    font-size: 1rem;
    line-height: 1.625;
    color: var(--color-text-secondary);
    margin-top: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }
  @media (prefers-reduced-motion: reduce) {
    .case-prose h2 {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
