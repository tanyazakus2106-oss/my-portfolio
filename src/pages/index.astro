---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedCard from '../components/FeaturedCard.astro';
import { getCollection } from 'astro:content';

const featured = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Tanya Zakus — UX/UI Designer">

  {/* Hero section — full screen height, vertically centered */}
  <section class="min-h-[800px] min-h-svh flex items-center px-[var(--spacing-lg)] md:px-[var(--spacing-2xl)] lg:px-[var(--spacing-3xl)]">
    <div class="max-w-[1200px] mx-auto w-full">
      <div class="max-w-[760px]">
        <p class="text-[13px] uppercase tracking-[0.08em] font-normal text-[var(--color-text-secondary)]">Open to full-time &amp; freelance</p>
        <h1 class="mt-[var(--spacing-md)] text-5xl md:text-6xl lg:text-7xl font-semibold leading-[1.1] text-[var(--color-text-primary)]">Tanya Zakus</h1>
        <p class="mt-[var(--spacing-lg)] text-2xl font-semibold leading-[1.25] text-[var(--color-text-primary)]">Product designer who shapes ideas into usable experiences.</p>
        <p class="mt-[var(--spacing-md)] text-base leading-[1.6] text-[var(--color-text-secondary)]">UX research, wireframes, prototyping, and handoff — end to end.</p>
      </div>
    </div>
  </section>

  {/* Divider between hero and selected work */}
  <div class="max-w-[1200px] mx-auto px-[var(--spacing-lg)] md:px-[var(--spacing-2xl)] lg:px-[var(--spacing-3xl)]">
    <hr class="border-t border-[var(--color-border)]" />
  </div>

  {/* Selected Work section */}
  <section class="pt-[var(--spacing-3xl)] pb-[var(--spacing-3xl)] px-[var(--spacing-lg)] md:px-[var(--spacing-2xl)] lg:px-[var(--spacing-3xl)]">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="text-2xl font-semibold text-[var(--color-text-primary)] mb-[var(--spacing-2xl)]">Selected Work</h2>
      <div class="flex flex-col gap-[100px]">
        {featured.map((entry, i) => <FeaturedCard entry={entry} index={i} />)}
      </div>
      <a
        href="/work"
        class="group mt-[var(--spacing-2xl)] inline-flex items-center text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
      >
        <span class="group-hover:underline underline-offset-4">View all work</span>&nbsp;→
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  import '../scripts/scroll-animation.ts';
</script>
