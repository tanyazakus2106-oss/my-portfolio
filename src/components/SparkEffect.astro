<canvas
  id="sparks"
  style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; background: transparent;"
></canvas>

<script>
  const canvas = document.getElementById('sparks') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  const OPT = {
    amount: 5000,
    speed: window.innerWidth < 520 ? 0.05 : 0.05,
    lifetime: 200,
    direction: { x: -0.5, y: 1 },
    size: [2, 2] as [number, number],
    maxopacity: 1,
    color: window.innerWidth < 520 ? '150,150,150' : '150,150,150',
    randColor: true,
    acceleration: [5, 40] as [number, number],
  };

  function setCanvasSize() {
    canvas.width = window.innerWidth;
    canvas.height = (canvas.parentElement as HTMLElement).offsetHeight;
  }

  function rand(min: number, max: number) {
    return Math.floor(Math.random() * (max - min + 1)) + min;
  }

  interface Spark {
    x: number;
    y: number;
    age: number;
    acceleration: number;
    color: string;
    opacity: number;
    go(): void;
  }

  function createSpark(x: number, y: number): Spark {
    const acc = rand(OPT.acceleration[0], OPT.acceleration[1]);
    const color = OPT.randColor
      ? `${rand(0, 255)},${rand(0, 255)},${rand(0, 255)}`
      : OPT.color;
    let age = 0;
    const spark: Spark = {
      x, y, age, acceleration: acc, color,
      opacity: OPT.maxopacity,
      go() {
        this.x += OPT.speed * OPT.direction.x * this.acceleration / 2;
        this.y += OPT.speed * OPT.direction.y * this.acceleration / 2;
        this.opacity = OPT.maxopacity - ++this.age / OPT.lifetime;
      },
    };
    return spark;
  }

  let sparks: Spark[] = [];

  function addSpark() {
    const x = rand(-200, window.innerWidth + 200);
    const y = rand(-200, canvas.height + 200);
    sparks.push(createSpark(x, y));
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (let i = sparks.length - 1; i >= 0; i--) {
      const spark = sparks[i];
      if (spark.opacity <= 0) {
        sparks.splice(i, 1);
        continue;
      }
      const { x, y } = spark;
      spark.go();
      ctx.beginPath();
      ctx.fillStyle = `rgba(${spark.color},${spark.opacity})`;
      ctx.rect(x, y, OPT.size[0], OPT.size[1]);
      ctx.fill();
    }
    requestAnimationFrame(draw);
  }

  window.addEventListener('resize', setCanvasSize);
  setCanvasSize();
  setInterval(() => {
    if (sparks.length < OPT.amount) addSpark();
  }, 1000 / OPT.amount);
  requestAnimationFrame(draw);
</script>
