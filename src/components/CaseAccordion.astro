---
interface Props {
  title: string;
  open?: boolean;
}
const { title, open = false } = Astro.props;
---

{
  /*
  Zero-JS accordion row for case-study body content, built on native
  <details>/<summary> (keyboard + screen-reader behavior for free). The
  title is an h4 to keep the document outline identical to the plain
  subheader form it replaces; slotted MDX (lists, paragraphs) is styled
  by the .case-prose rules in src/pages/projects/[id].astro.
*/
}
<details open={open}>
  <summary>
    <h4>{title}</h4>
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path
        d="M3 6l5 5 5-5"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </summary>
  <div class="body">
    <slot />
  </div>
</details>

<style>
  details {
    border-bottom: 1px solid var(--color-border);
    interpolate-size: allow-keywords;
  }
  /* Smooth slide open/close — native ::details-content transition
     (Chromium + newer Safari; others degrade to an instant toggle).
     Inside the reduced-motion guard so it never animates for users who
     opt out. */
  @media (prefers-reduced-motion: no-preference) {
    details::details-content {
      block-size: 0;
      overflow-y: clip;
      transition:
        content-visibility 400ms allow-discrete,
        block-size 400ms cubic-bezier(0.4, 0, 0.2, 1);
    }
    details[open]::details-content {
      block-size: auto;
    }
  }
  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    padding-block: var(--spacing-lg);
    cursor: pointer;
    list-style: none;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  summary:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  /* Serif family comes from the global h1–h4 rule; size/weight/color
     mirror the .case-prose > h4 subheader so both forms read the same. */
  summary h4 {
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.375;
    color: var(--color-text-primary);
  }
  summary svg {
    flex-shrink: 0;
    color: var(--color-text-secondary);
  }
  details[open] summary svg {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: no-preference) {
    summary svg {
      transition: transform 400ms cubic-bezier(0.4, 0, 0.2, 1);
    }
  }
  .body {
    /* Mirrors the .case-prose grid rhythm for slotted block siblings
       (paragraph + diagram, etc.). */
    display: grid;
    row-gap: var(--spacing-md);
    padding-bottom: var(--spacing-lg);
  }
</style>
