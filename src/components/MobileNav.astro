---
const links = [
  { href: '/', label: 'Work', external: false },
  { href: '/about', label: 'About', external: false },
  { href: '/tanya-zakus-designer-resume.pdf', label: 'Resume', external: true },
  { href: 'https://www.linkedin.com/in/tanya-zakus/', label: 'LinkedIn', external: true },
];
---

<!-- Hamburger trigger (visible only <768px; parent slot is already md:hidden) -->
<button
  id="mobile-nav-trigger"
  type="button"
  class="min-h-[44px] min-w-[44px] inline-flex items-center justify-center rounded-md p-[var(--spacing-sm)] text-[var(--color-text-primary)] hover:bg-[var(--color-secondary)] focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2"
  aria-label="Open navigation"
  aria-expanded="false"
  aria-controls="mobile-nav-overlay"
>
  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="3" y1="6" x2="21" y2="6"/>
    <line x1="3" y1="12" x2="21" y2="12"/>
    <line x1="3" y1="18" x2="21" y2="18"/>
  </svg>
</button>

<!-- Full-screen overlay dialog -->
<div
  id="mobile-nav-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation"
  class="fixed inset-0 z-[60] bg-[var(--color-background)] opacity-0 pointer-events-none transition-opacity duration-200 ease-out motion-reduce:transition-none"
  data-state="closed"
>
  <!-- Close (X) button top-right -->
  <button
    id="mobile-nav-close"
    type="button"
    class="absolute top-[var(--spacing-md)] right-[var(--spacing-md)] min-h-[44px] min-w-[44px] inline-flex items-center justify-center rounded-md p-[var(--spacing-sm)] text-[var(--color-text-primary)] hover:bg-[var(--color-secondary)] focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2"
    aria-label="Close navigation"
  >
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <!-- Nav links — centered, large type -->
  <nav aria-label="Mobile navigation" class="flex h-full w-full items-center justify-center py-[var(--spacing-3xl)]">
    <ul id="mobile-nav-links" class="flex flex-col items-center gap-[var(--spacing-xl)]">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class="text-[2rem] font-semibold leading-[1.2] text-[var(--color-text-primary)] min-h-[44px] flex items-center focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2"
            data-mobile-nav-link
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<script>
  const trigger = document.getElementById('mobile-nav-trigger') as HTMLButtonElement | null;
  const overlay = document.getElementById('mobile-nav-overlay') as HTMLDivElement | null;
  const closeBtn = document.getElementById('mobile-nav-close') as HTMLButtonElement | null;

  if (trigger && overlay && closeBtn) {
    let isOpen = false;

    function getFocusable(): HTMLElement[] {
      if (!overlay) return [];
      return Array.from(
        overlay.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled])'
        )
      );
    }

    function open() {
      if (!overlay || !trigger) return;
      isOpen = true;
      overlay.dataset.state = 'open';
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100');
      trigger.setAttribute('aria-expanded', 'true');
      trigger.setAttribute('aria-label', 'Close navigation');
      const scrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${scrollY}px`;
      document.body.style.width = '100%';
      // Focus first focusable (close button) on next tick so transition has started
      requestAnimationFrame(() => {
        const focusables = getFocusable();
        focusables[0]?.focus();
      });
    }

    function close() {
      if (!overlay || !trigger) return;
      isOpen = false;
      overlay.dataset.state = 'closed';
      overlay.classList.add('opacity-0', 'pointer-events-none');
      overlay.classList.remove('opacity-100');
      trigger.setAttribute('aria-expanded', 'false');
      trigger.setAttribute('aria-label', 'Open navigation');
      const scrollY = parseInt(document.body.style.top || '0') * -1;
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      window.scrollTo(0, scrollY);
      trigger.focus();
    }

    trigger.addEventListener('click', open);
    closeBtn.addEventListener('click', close);

    // Backdrop click: close if click target is the overlay itself (not a child)
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) close();
    });

    // Link click closes overlay so SPA-ish feel works (and resets for next page)
    overlay.querySelectorAll<HTMLAnchorElement>('[data-mobile-nav-link]').forEach((a) => {
      a.addEventListener('click', close);
    });

    // Esc + focus trap
    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        close();
        return;
      }
      if (e.key === 'Tab') {
        const focusables = getFocusable();
        if (focusables.length === 0) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        const active = document.activeElement as HTMLElement | null;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }
</script>
