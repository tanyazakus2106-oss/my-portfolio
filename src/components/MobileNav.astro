---
const links = [
  { href: '/', label: 'Work', external: false },
  { href: '/about', label: 'About', external: false },
  { href: '/tanya-zakus-designer-resume.pdf', label: 'Resume', external: true },
  { href: 'https://www.linkedin.com/in/tanya-zakus/', label: 'LinkedIn', external: true },
];
---

<!--
  Single morphing toggle (hamburger ⇄ X). Lives in a fixed bar that mirrors the
  header's .container (24px side padding) + 80px height + vertical centering, so
  the icon sits exactly where the in-header slot reserves space — and the open/X
  state occupies the identical position. The bar is hoisted to <body> in JS so it
  escapes the header's stacking context (the scrolled header's backdrop-filter
  otherwise traps fixed descendants below the overlay). pointer-events-none on the
  bar lets taps fall through to the logo/theme toggle; only the button re-enables.
-->
<div
  id="mobile-nav-bar"
  class="md:hidden fixed top-0 inset-x-0 h-20 z-[70] pointer-events-none"
>
  <div class="container h-full flex items-center justify-end">
    <button
      id="mobile-nav-trigger"
      type="button"
      class="mobile-nav-btn pointer-events-auto min-h-[44px] min-w-[44px] inline-flex items-center justify-center rounded-md p-[var(--spacing-sm)] text-[var(--color-text-primary)] hover:bg-[var(--color-secondary)] focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="mobile-nav-overlay"
    >
      <span class="menu-icon" aria-hidden="true">
        <span class="bar bar-top"></span>
        <span class="bar bar-mid"></span>
        <span class="bar bar-bot"></span>
      </span>
    </button>
  </div>
</div>

<!-- Full-screen overlay dialog (links only — the toggle above handles close) -->
<div
  id="mobile-nav-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation"
  class="md:hidden fixed inset-0 z-[60] bg-[var(--color-background)] opacity-0 pointer-events-none transition-opacity duration-200 ease-out motion-reduce:transition-none"
  data-state="closed"
>
  <!-- Nav links — centered, large type -->
  <nav aria-label="Mobile navigation" class="flex h-full w-full items-center justify-center py-[var(--spacing-3xl)]">
    <ul id="mobile-nav-links" class="flex flex-col items-center gap-[var(--spacing-xl)]">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class="text-[2rem] font-semibold leading-[1.2] text-[var(--color-text-primary)] min-h-[44px] flex items-center focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2"
            data-mobile-nav-link
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<script>
  const bar = document.getElementById('mobile-nav-bar') as HTMLDivElement | null;
  const trigger = document.getElementById('mobile-nav-trigger') as HTMLButtonElement | null;
  const overlay = document.getElementById('mobile-nav-overlay') as HTMLDivElement | null;

  if (bar && trigger && overlay) {
    // Hoist the bar AND the overlay to be direct children of <body>. Both are
    // rendered inside <Header>, which gets `backdrop-filter: blur()` when scrolled.
    // Per the CSS Filter Effects spec, backdrop-filter establishes a containing
    // block for fixed descendants — so without this hoist, `fixed` positioning
    // anchors to the 80px header instead of the viewport, and the header's
    // z-index would trap the toggle below the overlay.
    if (bar.parentElement !== document.body) document.body.appendChild(bar);
    if (overlay.parentElement !== document.body) document.body.appendChild(overlay);

    let isOpen = false;

    function getFocusable(): HTMLElement[] {
      const links = overlay
        ? Array.from(overlay.querySelectorAll<HTMLElement>('a[href]'))
        : [];
      return trigger ? [trigger, ...links] : links;
    }

    function open() {
      if (!overlay || !trigger) return;
      isOpen = true;
      overlay.dataset.state = 'open';
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100');
      trigger.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
      trigger.setAttribute('aria-label', 'Close navigation');
      const scrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${scrollY}px`;
      document.body.style.width = '100%';
      // Focus first nav link on next tick so the transition has started
      requestAnimationFrame(() => {
        const link = overlay?.querySelector<HTMLElement>('[data-mobile-nav-link]');
        link?.focus();
      });
    }

    function close() {
      if (!overlay || !trigger) return;
      isOpen = false;
      overlay.dataset.state = 'closed';
      overlay.classList.add('opacity-0', 'pointer-events-none');
      overlay.classList.remove('opacity-100');
      trigger.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
      trigger.setAttribute('aria-label', 'Open navigation');
      const scrollY = parseInt(document.body.style.top || '0') * -1;
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      window.scrollTo(0, scrollY);
      trigger.focus();
    }

    trigger.addEventListener('click', () => (isOpen ? close() : open()));

    // Backdrop click: close if click target is the overlay itself (not a child)
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) close();
    });

    // Link click closes overlay so SPA-ish feel works (and resets for next page)
    overlay.querySelectorAll<HTMLAnchorElement>('[data-mobile-nav-link]').forEach((a) => {
      a.addEventListener('click', close);
    });

    // Esc + focus trap (trap spans the toggle button + overlay links)
    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        close();
        return;
      }
      if (e.key === 'Tab') {
        const focusables = getFocusable();
        if (focusables.length === 0) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        const active = document.activeElement as HTMLElement | null;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }
</script>

<style>
  /* Touch-device default: drop the hover background so the button doesn't
     appear "stuck pressed" after a tap. Same pattern as ThemeToggle. */
  @media (hover: none) {
    .mobile-nav-btn:hover {
      background-color: transparent;
    }
  }

  /* ─── Morphing hamburger ⇄ X icon ─── */
  .menu-icon {
    position: relative;
    display: block;
    width: 24px;
    height: 24px;
  }

  .bar {
    position: absolute;
    left: 2px;
    right: 2px;
    height: 2px;
    border-radius: 2px;
    background-color: currentColor;
    transform-origin: center;
    transition:
      transform 250ms ease-out,
      opacity 200ms ease-out;
  }

  /* Hamburger rest state: three evenly-spaced bars (centers at 7 / 12 / 17). */
  .bar-top {
    top: 6px;
  }
  .bar-mid {
    top: 11px;
  }
  .bar-bot {
    top: 16px;
  }

  /* Open state: collapse outer bars to center, rotate into an X, fade the middle. */
  #mobile-nav-trigger.is-open .bar-top {
    transform: translateY(5px) rotate(45deg);
  }
  #mobile-nav-trigger.is-open .bar-mid {
    opacity: 0;
  }
  #mobile-nav-trigger.is-open .bar-bot {
    transform: translateY(-5px) rotate(-45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .bar {
      transition: none;
    }
  }

  [data-mobile-nav-link] {
    font-family: var(--font-serif);
    font-weight: 400;
  }
</style>
