---
const links = [
  { href: "/", label: "Work", external: false },
  { href: "/about", label: "About", external: false },
  { href: "/tanya-zakus-designer-resume.pdf", label: "Resume", external: true },
  {
    href: "https://www.linkedin.com/in/tanya-zakus/",
    label: "LinkedIn",
    external: true,
  },
];
---

<!--
  Hamburger trigger. Rendered IN the sticky header slot (in flow) so it bounces
  in lockstep with the logo + theme toggle during overscroll — a fixed/hoisted
  toggle would stay pinned while the sticky header rubber-bands, which looks
  inconsistent. The morphing X is a separate button inside the overlay (below),
  pixel-aligned to this one, so the open-state icon is viewport-fixed without
  making the closed-state icon fixed.
-->
<button
  id="mobile-nav-trigger"
  type="button"
  class="mobile-nav-btn min-h-[44px] min-w-[44px] inline-flex items-center justify-center rounded-md p-[var(--spacing-sm)] text-[var(--color-text-primary)] hover:bg-[var(--color-secondary)] focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2"
  aria-label="Open navigation"
  aria-expanded="false"
  aria-controls="mobile-nav-overlay"
>
  <span class="menu-icon" aria-hidden="true">
    <span class="bar bar-top"></span>
    <span class="bar bar-mid"></span>
    <span class="bar bar-bot"></span>
  </span>
</button>

<!-- Full-screen overlay dialog -->
<div
  id="mobile-nav-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation"
  class="md:hidden fixed inset-0 z-[60] bg-[var(--color-background)] opacity-0 pointer-events-none transition-opacity duration-200 ease-out motion-reduce:transition-none"
  data-state="closed"
>
  <!--
    Top bar mirrors the header's .container (20px padding on mobile, 24px at md+) + 80px height +
    vertical centering, so the close X lands exactly where the hamburger sits.
    The two identical 3-bar icons overlap as the overlay fades in, so the X
    morph reads as continuous.
  -->
  <div class="absolute top-0 inset-x-0 h-20">
    <div class="container h-full flex items-center justify-end">
      <button
        id="mobile-nav-close"
        type="button"
        class="mobile-nav-btn min-h-[44px] min-w-[44px] inline-flex items-center justify-center rounded-md p-[var(--spacing-sm)] text-[var(--color-text-primary)] hover:bg-[var(--color-secondary)] focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2"
        aria-label="Close navigation"
      >
        <span class="menu-icon" aria-hidden="true">
          <span class="bar bar-top"></span>
          <span class="bar bar-mid"></span>
          <span class="bar bar-bot"></span>
        </span>
      </button>
    </div>
  </div>

  <!-- Nav links — centered, large type -->
  <nav
    aria-label="Mobile navigation"
    class="flex h-full w-full items-center justify-center py-[var(--spacing-3xl)]"
  >
    <ul
      id="mobile-nav-links"
      class="flex flex-col items-center gap-[var(--spacing-xl)]"
    >
      {
        links.map((link, index) => (
          <li>
            <a
              href={link.href}
              {...(link.external
                ? { target: "_blank", rel: "noopener noreferrer" }
                : {})}
              class="text-[2rem] font-semibold leading-[1.2] text-[var(--color-text-primary)] min-h-[44px] flex items-center focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2"
              style={`--i:${index}`}
              data-mobile-nav-link
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<script>
  const trigger = document.getElementById(
    "mobile-nav-trigger",
  ) as HTMLButtonElement | null;
  const overlay = document.getElementById(
    "mobile-nav-overlay",
  ) as HTMLDivElement | null;
  const closeBtn = document.getElementById(
    "mobile-nav-close",
  ) as HTMLButtonElement | null;

  if (trigger && overlay && closeBtn) {
    // Hoist the overlay to be a direct child of <body>. MobileNav is rendered
    // inside <Header>, which gets `backdrop-filter: blur()` when scrolled. Per the
    // CSS Filter Effects spec, backdrop-filter establishes a containing block for
    // fixed-positioned descendants — so without this hoist, the overlay's
    // `fixed inset-0` anchors to the 80px-tall header instead of the viewport.
    // (The trigger deliberately stays in the header so it tracks the sticky
    // header during overscroll instead of pinning like a fixed element.)
    if (overlay.parentElement !== document.body) {
      document.body.appendChild(overlay);
    }

    let isOpen = false;

    function getFocusable(): HTMLElement[] {
      if (!overlay) return [];
      return Array.from(
        overlay.querySelectorAll<HTMLElement>(
          "a[href], button:not([disabled])",
        ),
      );
    }

    function open() {
      if (!overlay || !trigger) return;
      isOpen = true;
      overlay.dataset.state = "open";
      overlay.classList.remove("opacity-0", "pointer-events-none");
      overlay.classList.add("opacity-100");
      trigger.setAttribute("aria-expanded", "true");
      const scrollY = window.scrollY;
      document.body.style.position = "fixed";
      document.body.style.top = `-${scrollY}px`;
      document.body.style.width = "100%";
      // Focus the close button on next tick so the transition has started
      requestAnimationFrame(() => {
        const focusables = getFocusable();
        focusables[0]?.focus();
      });
    }

    function close() {
      if (!overlay || !trigger) return;
      isOpen = false;
      overlay.dataset.state = "closed";
      overlay.classList.add("opacity-0", "pointer-events-none");
      overlay.classList.remove("opacity-100");
      trigger.setAttribute("aria-expanded", "false");
      const scrollY = parseInt(document.body.style.top || "0") * -1;
      document.body.style.position = "";
      document.body.style.top = "";
      document.body.style.width = "";
      window.scrollTo(0, scrollY);
      trigger.focus();
    }

    trigger.addEventListener("click", open);
    closeBtn.addEventListener("click", close);

    // Backdrop click: close if click target is the overlay itself (not a child)
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) close();
    });

    // Link click closes overlay so SPA-ish feel works (and resets for next page)
    overlay
      .querySelectorAll<HTMLAnchorElement>("[data-mobile-nav-link]")
      .forEach((a) => {
        a.addEventListener("click", close);
      });

    // Esc + focus trap
    document.addEventListener("keydown", (e) => {
      if (!isOpen) return;
      if (e.key === "Escape") {
        e.preventDefault();
        close();
        return;
      }
      if (e.key === "Tab") {
        const focusables = getFocusable();
        if (focusables.length === 0) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        const active = document.activeElement as HTMLElement | null;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }
</script>

<style>
  /* Touch-device default: drop the hover background so the button doesn't
     appear "stuck pressed" after a tap. Same pattern as ThemeToggle. */
  @media (hover: none) {
    .mobile-nav-btn:hover {
      background-color: transparent;
    }
  }

  /* Optical alignment: the drawn bars end 12px inside the button box —
     (44px button − 24px icon)/2 centering + 2px bar inset. Pull the button
     right by that amount so the ink (not the invisible 44×44 hit area)
     aligns to the container gutter. Applies to both the header trigger and
     the overlay X, which must stay pixel-aligned for the morph illusion. */
  .mobile-nav-btn {
    margin-right: -12px;
  }

  /* ─── Hamburger ⇄ X icon ─── */
  .menu-icon {
    position: relative;
    display: block;
    width: 24px;
    height: 24px;
  }

  .bar {
    position: absolute;
    left: 2px;
    right: 2px;
    height: 2px;
    border-radius: 2px;
    background-color: currentColor;
    transform-origin: center;
    transition:
      transform 250ms ease-out,
      opacity 200ms ease-out;
  }

  /* Hamburger rest state: three evenly-spaced bars (centers at 7 / 12 / 17). */
  .bar-top {
    top: 6px;
  }
  .bar-mid {
    top: 11px;
  }
  .bar-bot {
    top: 16px;
  }

  /* Open state morphs ONLY the overlay's close icon into an X; the header
     hamburger (not inside the overlay) stays a hamburger and is hidden behind
     the opaque overlay. The two icons are pixel-aligned, so the fade-in reads
     as a single continuous morph. */
  #mobile-nav-overlay[data-state="open"] .bar-top {
    transform: translateY(5px) rotate(45deg);
  }
  #mobile-nav-overlay[data-state="open"] .bar-mid {
    opacity: 0;
  }
  #mobile-nav-overlay[data-state="open"] .bar-bot {
    transform: translateY(-5px) rotate(-45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .bar {
      transition: none;
    }
  }

  /* ─── Staggered link entrance ─── */
  [data-mobile-nav-link] {
    font-family: var(--font-serif);
    font-weight: 400;
    /* Resting/closed state: nudged below + hidden. The overlay is itself hidden
       (opacity-0 / pointer-events-none) when closed, so these never flash before
       open. transition-delay defaults to 0 here, so on CLOSE all items leave
       together as the overlay fades — only the OPEN state staggers. */
    opacity: 0;
    transform: translateY(1.5rem);
    transition:
      opacity 500ms ease-out,
      transform 500ms ease-out;
  }

  /* Open: rise into place + fade in, staggered 60ms per item (project rhythm). */
  #mobile-nav-overlay[data-state="open"] [data-mobile-nav-link] {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--i, 0) * 60ms);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-mobile-nav-link] {
      transition: none;
    }
    #mobile-nav-overlay[data-state="open"] [data-mobile-nav-link] {
      transition-delay: 0ms;
    }
  }
</style>
