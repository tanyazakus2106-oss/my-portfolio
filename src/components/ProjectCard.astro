---
/**
 * ProjectCard.astro — Work index page card (Phase 03, WORK-01..WORK-06)
 *
 * Design decisions:
 * - Numbers removed; alternating layout and hover image scale preserved.
 * - Text column is center-aligned.
 * - No hover shadow — image scale only.
 * - animate-on-scroll class hooks into CSS defined in global.css + stagger via
 *   scroll-animation.ts (loaded by the consuming page, not this component).
 */
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'projects'>;
  index: number; // 0-based position; drives alternating layout
}

const { entry, index } = Astro.props;
const isReversed = index % 2 === 1;
---

<article
  class:list={[
    'group animate-on-scroll',
    'rounded-lg overflow-hidden',
    'focus-within:outline-2 focus-within:outline-offset-2 focus-within:outline-[var(--color-accent)]',
  ]}
>
  <a
    href={`/projects/${entry.id}`}
    aria-label={`${entry.data.title} — View project`}
    class:list={[
      'flex flex-col md:flex-row gap-[var(--spacing-xl)] items-center',
      isReversed ? 'md:flex-row-reverse' : '',
      'no-underline',
    ]}
  >
    {/* 60% image column */}
    <div class="md:basis-[60%] w-full overflow-hidden rounded-lg">
      <Image
        src={entry.data.thumbnail}
        alt={`Project thumbnail for ${entry.data.title}`}
        format="webp"
        widths={[600, 1200]}
        sizes="(min-width: 768px) 60vw, 100vw"
        class="w-full h-full object-cover aspect-[4/3] transition-transform duration-[400ms] ease-out group-hover:scale-[1.06]"
      />
    </div>

    {/* 40% text column — center-aligned */}
    <div class="md:basis-[40%] flex flex-col items-center text-center gap-[var(--spacing-md)] px-[var(--spacing-lg)] md:px-[var(--spacing-xl)] py-[var(--spacing-md)]">
      <p class="text-[13px] uppercase tracking-[0.08em] text-[var(--color-text-secondary)]">
        {entry.data.role}
      </p>
      <h2 class="text-2xl font-semibold leading-[1.25] text-[var(--color-text-primary)]">
        {entry.data.title}
      </h2>
      <ul class="flex flex-wrap justify-center gap-[var(--spacing-xs)]">
        {entry.data.skills.map((skill) => (
          <li class="text-[13px] leading-[1] px-[var(--spacing-sm)] py-[var(--spacing-xs)] rounded-full bg-[var(--color-secondary)] text-[var(--color-text-secondary)]">
            {skill}
          </li>
        ))}
      </ul>
      <p class="text-base leading-[1.6] text-[var(--color-text-secondary)]">
        {entry.data.summary}
      </p>
      <span class="text-base text-[var(--color-accent)]" aria-hidden="true">
        <span class="group-hover:underline underline-offset-4">View project</span> →
      </span>
    </div>
  </a>
</article>
