---
const navLinks = [
  { href: '/work', label: 'Work', external: false },
  { href: '/about', label: 'About', external: false },
  { href: '/resume.pdf', label: 'Resume', external: false },
  { href: 'https://linkedin.com', label: 'LinkedIn', external: true },
];

const EMAIL = 'tanyazakus2106@gmail.com';
const LINKEDIN_URL = 'https://linkedin.com';
---

<footer class="bg-[var(--color-secondary)] border-t border-[var(--color-border)] py-[var(--spacing-2xl)]">
  <div class="max-w-[1200px] mx-auto px-[var(--spacing-lg)] md:px-[var(--spacing-2xl)] lg:px-[var(--spacing-3xl)]">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-[var(--spacing-xl)]">

      <!-- Left column: CTA + social icons -->
      <div class="flex flex-col gap-[var(--spacing-md)]">
        <p class="text-2xl font-semibold leading-[1.25] text-[var(--color-text-primary)]">
          Let's work together.
        </p>
        <a
          href={`mailto:${EMAIL}`}
          class="inline-flex items-center min-h-[44px] text-base font-normal text-[var(--color-accent)] hover:underline focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2 w-fit"
        >
          Get in touch →
        </a>

        <!-- Social icon links — FOOT-02: LinkedIn + email -->
        <ul class="flex items-center gap-[var(--spacing-md)] mt-[var(--spacing-sm)]" aria-label="Social links">
          <li>
            <a
              href={LINKEDIN_URL}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn profile"
              class="min-h-[44px] min-w-[44px] inline-flex items-center justify-center rounded-md text-[var(--color-text-primary)] hover:text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2 transition-colors"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.95v5.66H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
              </svg>
            </a>
          </li>
          <li>
            <a
              href={`mailto:${EMAIL}`}
              aria-label="Email Tanya"
              class="min-h-[44px] min-w-[44px] inline-flex items-center justify-center rounded-md text-[var(--color-text-primary)] hover:text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2 transition-colors"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-10 6L2 7"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- Right column: mirrored nav links (FOOT-01) -->
      <nav aria-label="Footer navigation" class="md:justify-self-end">
        <ul class="flex flex-col gap-[var(--spacing-sm)]">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                class="inline-flex items-center min-h-[44px] text-base font-normal text-[var(--color-text-primary)] hover:text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2 transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

    </div>

    <!-- Copyright row -->
    <p class="mt-[var(--spacing-2xl)] text-sm font-normal text-[var(--color-text-secondary)]">
      &copy; 2026 Tanya Zakus
    </p>
  </div>
</footer>
