---
import ThemeToggle from "./ThemeToggle.astro";
import MobileNav from "./MobileNav.astro";

const pathname = Astro.url.pathname;
const links = [
  { href: "/", label: "Work", external: false },
  { href: "/about", label: "About", external: false },
  { href: "/tanya-zakus-designer-resume.pdf", label: "Resume", external: true },
  {
    href: "https://www.linkedin.com/in/tanya-zakus/",
    label: "LinkedIn",
    external: true,
  },
];

function isActive(href: string): boolean {
  if (href.startsWith("http") || href.endsWith(".pdf")) return false;
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
}
---

<header
  id="site-header"
  class="sticky top-0 z-50 h-20 bg-transparent border-b border-transparent transition-[border-color,background-color,backdrop-filter] duration-500 ease-out"
>
  <div class="container h-full flex items-center justify-between">
    <a
      href="/"
      class="min-h-[44px] flex items-center focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-4 rounded-full"
      aria-label="Tanya Zakus — home"
    >
      <span class="tz-logo" aria-hidden="true">tz</span>
    </a>

    <div class="flex items-center">
      <nav aria-label="Main navigation" class="hidden md:block">
        <ul class="flex items-center gap-[var(--spacing-lg)]">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  {...(link.external
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                  class:list={[
                    "group min-h-[44px] flex items-center text-base font-normal transition-[color] duration-150 hover:text-[var(--color-text-primary)]",
                    isActive(link.href)
                      ? "text-[var(--color-text-primary)]"
                      : "text-[var(--color-text-secondary)]",
                  ]}
                  aria-current={isActive(link.href) ? "page" : undefined}
                >
                  <span
                    class:list={[
                      "relative",
                      'after:content-[""] after:absolute after:left-0 after:right-0 after:-bottom-[4px] after:h-[2px] after:bg-[var(--color-accent)] after:transition-opacity after:duration-150',
                      isActive(link.href)
                        ? "after:opacity-100"
                        : "after:opacity-0",
                    ]}
                  >
                    {link.label}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Hamburger button slot — filled in Plan 02 (Wave 2). -->
      <div id="header-mobile-slot" class="md:hidden mr-2">
        <MobileNav />
      </div>

      <span
        class="hidden md:block w-px h-4 bg-[var(--color-border)] ml-[24px]"
        aria-hidden="true"></span>
      <div class="ml-[16px]"><ThemeToggle /></div>
    </div>
  </div>
</header>

<style>
  .tz-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: color-mix(
      in srgb,
      var(--color-text-primary) 8%,
      transparent
    );
    color: var(--color-text-primary);
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 500;
    font-style: normal;
    letter-spacing: -0.03em;
    user-select: none;
    flex-shrink: 0;
    transition:
      background-color 150ms ease-out,
      color 150ms ease-out;
  }

  a:hover .tz-logo {
    background-color: color-mix(in srgb, var(--color-accent) 14%, transparent);
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .tz-logo {
      transition: none;
    }
  }

  #site-header {
    backdrop-filter: blur(0px);
  }
  #site-header.is-scrolled {
    background-color: color-mix(
      in srgb,
      var(--color-background) 95%,
      transparent
    );
    backdrop-filter: blur(6px);
    border-bottom-color: color-mix(
      in srgb,
      var(--color-border) 67%,
      transparent
    );
  }
</style>

<script>
  const header = document.getElementById("site-header");
  let showTimer: ReturnType<typeof setTimeout> | null = null;

  function updateHeader() {
    if (window.scrollY > 0) {
      if (!header?.classList.contains("is-scrolled") && !showTimer) {
        showTimer = setTimeout(() => {
          header?.classList.add("is-scrolled");
          showTimer = null;
        }, 150);
      }
    } else {
      if (showTimer) {
        clearTimeout(showTimer);
        showTimer = null;
      }
      header?.classList.remove("is-scrolled");
    }
  }

  updateHeader();
  window.addEventListener("scroll", updateHeader, { passive: true });
</script>
