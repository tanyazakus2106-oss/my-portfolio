---
import ThemeToggle from './ThemeToggle.astro';
import MobileNav from './MobileNav.astro';

const pathname = Astro.url.pathname;
const links = [
  { href: '/work', label: 'Work', external: false },
  { href: '/about', label: 'About', external: false },
  { href: '/resume.pdf', label: 'Resume', external: false },
  { href: 'https://linkedin.com', label: 'LinkedIn', external: true },
];

function isActive(href: string): boolean {
  if (href.startsWith('http') || href.endsWith('.pdf')) return false;
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
}
---

<header class="sticky top-0 z-50 h-16 bg-[color-mix(in_srgb,var(--color-dominant)_95%,transparent)] backdrop-blur-sm border-b border-[var(--color-border)]">
  <div class="max-w-[1200px] mx-auto px-[var(--spacing-lg)] md:px-[var(--spacing-2xl)] lg:px-[var(--spacing-3xl)] h-full flex items-center justify-between">
    <a href="/" class="font-semibold text-[var(--color-text-primary)] min-h-[44px] flex items-center focus-visible:outline-2 focus-visible:outline-[var(--color-accent)] focus-visible:outline-offset-2 rounded-sm">Tanya Zakus</a>

    <div class="flex items-center gap-[var(--spacing-md)]">
      <nav aria-label="Main navigation" class="hidden md:block">
        <ul class="flex items-center gap-[var(--spacing-lg)]">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                class:list={[
                  'relative min-h-[44px] flex items-center text-base font-normal text-[var(--color-text-primary)] transition-[color] duration-150',
                  'after:content-[""] after:absolute after:left-0 after:right-0 after:-bottom-0.5 after:h-[2px] after:bg-[var(--color-accent)] after:transition-opacity after:duration-150',
                  isActive(link.href) ? 'after:opacity-100' : 'after:opacity-0 hover:after:opacity-100',
                ]}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Hamburger button slot — filled in Plan 02 (Wave 2). -->
      <div id="header-mobile-slot" class="md:hidden">
        <MobileNav />
      </div>

      <ThemeToggle />
    </div>
  </div>
</header>
