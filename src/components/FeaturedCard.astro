---
/**
 * FeaturedCard.astro — Homepage "Selected Work" card
 *
 * Identical layout to ProjectCard: alternating 60/40, text left-aligned,
 * card row vertically centered. Includes skills list. No hover shadow.
 */
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import ArrowLink from './ui/ArrowLink.astro';

interface Props {
  entry: CollectionEntry<'projects'>;
  index: number;
}

const { entry, index } = Astro.props;
const isReversed = index % 2 === 1;
---

<article
  class:list={[
    'group animate-on-scroll',
    'focus-within:outline-2 focus-within:outline-offset-2 focus-within:outline-[var(--color-accent)]',
  ]}
>
  <a
    href={`/projects/${entry.id}`}
    aria-label={`${entry.data.title} — View project`}
    class:list={[
      'flex flex-col md:flex-row gap-[var(--spacing-xl)] md:gap-[56px] items-center',
      isReversed ? 'md:flex-row-reverse' : '',
      'no-underline',
    ]}
  >
    {/* 60% image column */}
    <div class="md:basis-[60%] w-full overflow-hidden rounded-lg">
      <Image
        src={entry.data.thumbnail}
        alt={`Project thumbnail for ${entry.data.title}`}
        format="webp"
        widths={[600, 1200]}
        sizes="(min-width: 768px) 60vw, 100vw"
        class="w-full h-full object-cover aspect-[4/3] transition-transform duration-[400ms] ease-out group-hover:scale-[1.06]"
      />
    </div>

    {/* 40% text column — left-aligned */}
    <div class="md:basis-[40%] flex flex-col items-start text-left gap-[var(--spacing-md)] py-[var(--spacing-md)]">
      <p class="text-xs uppercase tracking-[0.08em] text-[var(--color-text-secondary)]">
        {entry.data.role}
      </p>
      <h3 class="text-[36px] leading-[40px] text-[var(--color-text-primary)]">
        {entry.data.title}
      </h3>
      <p class="text-lg text-[var(--color-text-secondary)]">
        {entry.data.summary}
      </p>
      <ArrowLink decorative aria-hidden="true">View project</ArrowLink>
    </div>
  </a>
</article>
