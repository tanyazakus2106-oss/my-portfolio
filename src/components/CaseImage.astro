---
import { Image } from "astro:assets";
interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}
const { src, alt, caption } = Astro.props;
---

{/* +8px own margin on top of the .case-prose rhythm (all breakpoints):
   row-gap 16 + 8 = 24px above; row-gap 16 + h3 margin-top 16 + 8 = 40px
   below the image. */}
<figure class="my-[var(--spacing-sm)]">
  <Image
    src={src}
    alt={alt}
    widths={[400, 720, 1440]}
    sizes="(min-width: 768px) 720px, calc(100vw - 3rem)"
    class="w-full h-auto rounded-2xl"
  />
  {
    caption && (
      <figcaption class="mt-[var(--spacing-sm)] text-sm text-[var(--color-text-secondary)]">
        {caption}
      </figcaption>
    )
  }
</figure>
