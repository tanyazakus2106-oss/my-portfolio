---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Tanya Zakus — UX/UI Designer",
  description = "",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-sans text-[var(--color-text-primary)] bg-[var(--color-dominant)]">
    <header class="sticky top-0 z-50 h-16 bg-[color-mix(in_srgb,var(--color-dominant)_95%,transparent)] backdrop-blur-sm border-b border-[var(--color-border)]">
      <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-16 h-full flex items-center justify-between">
        <span class="font-semibold">Tanya Zakus</span>
        <nav>
          <ul class="flex items-center gap-6">
            <li>
              <a href="/work" class="min-h-[44px] flex items-center">Work</a>
            </li>
            <li>
              <a href="/about" class="min-h-[44px] flex items-center">About</a>
            </li>
            <li>
              <a href="/resume.pdf" class="min-h-[44px] flex items-center">Resume</a>
            </li>
            <li>
              <a
                href="https://linkedin.com"
                target="_blank"
                rel="noopener noreferrer"
                class="min-h-[44px] flex items-center"
              >LinkedIn</a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-[var(--color-secondary)] py-12">
      <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-16">
        <p class="text-lg font-semibold mb-4">Let's work together.</p>
        <a href="mailto:" class="text-[var(--color-accent)] hover:underline">Get in touch</a>
        <p class="mt-8 text-[var(--color-text-secondary)] text-sm">&copy; 2026 Tanya Zakus</p>
      </div>
    </footer>
  </body>
</html>
